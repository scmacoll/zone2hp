# Zone Two — booking + accounts configuration (example).
# Copy to .env and adjust. .env is gitignored; never commit real values.
#
# The PUBLIC_* vars below are inlined into the static build and are NOT secret.
# Because the site is statically generated, changing one needs a rebuild.

# How /book renders:
#   mock      custom in-site UI driven by the built-in mock provider (default)
#   api       custom in-site UI driven by a real provider (needs a backend, not yet wired)
#   embedded  frames the provider's own hosted booking page (BookingEmbed)
PUBLIC_BOOKING_MODE=mock

# Which provider getBookingProvider() selects once a backend exists (mock | cliniko).
PUBLIC_BOOKING_PROVIDER=mock

# Hosted booking page URL, used by BookingEmbed when PUBLIC_BOOKING_MODE=embedded.
# e.g. https://your-subdomain.au4.cliniko.com/bookings
PUBLIC_BOOKING_EMBED_URL=

# Show the nav's Log in + Book now buttons on the live home. On by default; set
# to false to revert the home to a pure coming-soon nav.
PUBLIC_BOOKING_LINKS_VISIBLE=true

# Show the private-health-funding (HALTH-style) step in the booking funnel. On by
# default; set to false to remove the funding step entirely.
PUBLIC_BOOKING_FUNDING=true

# -----------------------------------------------------------------------------
# SERVER-ONLY secrets. Do NOT add a PUBLIC_ prefix (that would expose them to the
# browser). They are unused until a server runtime / serverless function exists
# to hold them; the static build never reads them. Never commit real values.
# -----------------------------------------------------------------------------

# Cliniko API key (HTTP Basic auth, broad access to patient data). Server-only.
CLINIKO_API_KEY=
# Cliniko region shard, e.g. au1, au2, au3, au4, uk1. Server-only.
CLINIKO_SHARD=
