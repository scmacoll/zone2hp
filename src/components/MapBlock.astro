---
// Embedded map of the Eastwood address with the written address beside it.
// Keyless Google Maps embed (output=embed needs no API key). The block reflows
// from side-by-side to stacked on its own container width via a container query,
// which is the fix for the split-window case.
import Eyebrow from './Eyebrow.astro';

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;

const address1 = 'Suite 104 / 2 Rowe St,';
const address2 = 'Eastwood, NSW 2122';
const query = 'Suite 104/2 Rowe St, Eastwood NSW 2122';
const mapSrc = `https://www.google.com/maps?q=${encodeURIComponent(query)}&output=embed`;
const mapsLink = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(query)}`;
---

<section class:list={['map', className]} aria-labelledby="map-heading">
  <div class="map__grid">
    <div class="map__frame">
      <iframe
        title="Map showing Zone Two Health and Performance at Suite 104 / 2 Rowe St, Eastwood NSW 2122"
        src={mapSrc}
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"></iframe>
    </div>

    <div class="map__details">
      <Eyebrow>Find us in Eastwood</Eyebrow>
      <h2 id="map-heading" class="map__title">Eastwood, NSW</h2>
      <address class="map__address">
        {address1}<br />{address2}
      </address>
      <a class="map__link" href={mapsLink} target="_blank" rel="noopener noreferrer">
        Open in Google Maps
      </a>
    </div>
  </div>
</section>

<style>
  /* .map is the query container; .map__grid (its child) reflows on the
     block's own width, so it works full width or split in half. */
  .map {
    container-type: inline-size;
  }
  .map__grid {
    display: grid;
    gap: var(--space-md);
  }

  @container (min-width: 38rem) {
    .map__grid {
      grid-template-columns: 1.5fr 1fr;
      align-items: stretch;
    }
  }

  .map__frame {
    overflow: hidden;
    border: var(--border-hairline);
    border-radius: var(--radius-md);
    background: var(--chrome);
  }
  .map__frame iframe {
    width: 100%;
    height: 100%;
    min-height: 16rem;
    aspect-ratio: 16 / 10;
    border: 0;
  }

  .map__details {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    align-content: start;
  }
  .map__title {
    font-size: var(--step-h3);
  }
  .map__address {
    font-style: normal;
    color: var(--ink-2);
    line-height: 1.45;
  }
  .map__link {
    align-self: start;
    min-height: 2.75rem;
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: var(--step-label);
    letter-spacing: var(--track-label);
    text-transform: uppercase;
    color: var(--accent-deep);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
  }
  .map__link:hover {
    color: var(--accent-press);
  }
</style>
