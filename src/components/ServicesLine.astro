---
// One-line services summary in mono. Separators are decorative (aria-hidden) so
// screen readers read the four services cleanly. Wraps gracefully on narrow
// containers rather than overflowing.
interface Props {
  class?: string;
  [key: string]: unknown;
}

const { class: className = '', ...rest } = Astro.props;
const services = ['Chiropractic', 'Rehab', 'Exercise Physiology', 'Dry Needling'];
---

<p class:list={['services', className]} {...rest}>
  {
    services.map((service, i) => (
      <>
        {i > 0 && (
          <span class="services__sep" aria-hidden="true">
            ·
          </span>
        )}
        <span class="services__item">{service}</span>
      </>
    ))
  }
</p>

<style>
  .services {
    display: flex;
    flex-wrap: wrap;
    justify-content: inherit;
    align-items: baseline;
    gap: 0.4rem 0.85rem;
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--step-label);
    font-weight: 500;
    letter-spacing: var(--track-label);
    text-transform: uppercase;
    color: var(--ink-2);
  }
  .services__sep {
    color: var(--accent);
  }
</style>
