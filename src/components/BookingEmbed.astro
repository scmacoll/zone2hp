---
// Embedded booking mode (the optional fast-launch fallback). Frames the practice
// booking system's own hosted page. Until PUBLIC_BOOKING_EMBED_URL is set, shows
// a factual placeholder and loads no third-party content.
import { bookingConfig } from '../lib/booking/config';
import CtaButton from './CtaButton.astro';

const url = bookingConfig.embedUrl;
---

<section class="embed" aria-label="Online booking">
  {
    url ? (
      <Fragment>
        <iframe class="embed__frame" src={url} title="Online booking" loading="lazy" />
        <p class="embed__fallback">
          If the booking page does not load,{' '}
          <CtaButton href={url} variant="outline" target="_blank" rel="noopener noreferrer">
            open it in a new tab
          </CtaButton>
        </p>
      </Fragment>
    ) : (
      <div class="embed__placeholder">
        <p class="embed__title">The online booking page will appear here.</p>
        <p class="embed__note">
          In embedded mode this frames the practice booking system's own page. Set
          <code>PUBLIC_BOOKING_EMBED_URL</code> to preview it.
        </p>
      </div>
    )
  }
</section>

<style>
  .embed {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--section-pad-inline);
    padding-block: var(--space-lg);
  }
  .embed__frame {
    width: 100%;
    min-height: 70svh;
    border: var(--border-hairline);
    border-radius: var(--radius-md);
    background: var(--stone);
  }
  .embed__fallback {
    margin-top: var(--space-sm);
    font-size: var(--step-small);
    color: var(--ink-2);
  }
  .embed__placeholder {
    display: grid;
    gap: var(--space-sm);
    place-content: center;
    text-align: center;
    min-height: 60svh;
    padding: var(--space-lg);
    border: 1px dashed var(--chrome-cool);
    border-radius: var(--radius-md);
    background: var(--grad-chrome);
  }
  .embed__title {
    font-family: var(--font-display);
    font-size: var(--step-h3);
    color: var(--ink);
  }
  .embed__note {
    max-width: 44ch;
    margin-inline: auto;
    font-size: var(--step-small);
    color: var(--ink-2);
  }
  .embed__note code {
    font-family: var(--font-mono);
    font-size: 0.95em;
    background: var(--chrome);
    padding: 0.1em 0.35em;
    border-radius: var(--radius-sm);
  }
</style>
