---
// Full-bleed hero with a swappable media slot. The brand-graded gradient is the
// always-present base layer. Pass `poster` (and later `video`) using the exact
// ASSETS.md paths and the real still/loop drops in with no code change:
//   <Hero poster="/images/hero-a1-poster.jpg"
//         video={{ webm: '/video/hero-a1.webm', mp4: '/video/hero-a1.mp4' }}>
// On small screens and under reduced motion the video is hidden and the poster
// (or, in Phase 1, the gradient) shows. Text sits in a defined safe area.
interface Props {
  poster?: string;
  video?: { webm?: string; mp4?: string };
  align?: 'center' | 'start';
  scrollCue?: boolean;
  class?: string;
}

const { poster, video, align = 'center', scrollCue = false, class: className = '' } = Astro.props;
---

<section class:list={['hero', `hero--${align}`, className]}>
  <div class="hero__media" aria-hidden="true">
    {poster && <img class="hero__poster" src={poster} alt="" fetchpriority="high" />}
    {
      video && (
        <video class="hero__video" autoplay muted loop playsinline poster={poster}>
          {video.webm && <source src={video.webm} type="video/webm" />}
          {video.mp4 && <source src={video.mp4} type="video/mp4" />}
        </video>
      )
    }
  </div>

  <div class="hero__inner">
    <slot />
  </div>

  {
    scrollCue && (
      <div class="hero__cue" aria-hidden="true">
        <span class="hero__cue-label">Scroll</span>
        <span class="hero__cue-line" />
      </div>
    )
  }
</section>

<style>
  .hero {
    position: relative;
    container-type: inline-size;
    display: grid;
    min-height: 100vh; /* fallback */
    min-height: 100svh; /* avoids mobile browser-chrome clipping */
    overflow: clip;
    isolation: isolate;
  }

  .hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: var(--grad-hero);
  }

  .hero__poster,
  .hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    width: 100%;
    max-width: var(--container-max);
    margin-inline: auto;
    padding-block: var(--space-xl);
    padding-inline: var(--section-pad-inline);
  }

  .hero--center .hero__inner {
    justify-content: center;
    align-items: center;
    text-align: center;
  }
  .hero--start .hero__inner {
    justify-content: end;
    align-items: start;
    text-align: start;
  }

  /* Scroll cue, bottom-centre, with a slow travel that reduced motion stills. */
  .hero__cue {
    position: absolute;
    z-index: 1;
    bottom: var(--space-md);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: var(--step-label);
    letter-spacing: var(--track-label);
    text-transform: uppercase;
    color: var(--ink-2);
  }
  .hero__cue-line {
    width: 1px;
    height: 2.25rem;
    background: linear-gradient(var(--ink-3), transparent);
    transform-origin: top;
    animation: hero-cue 2.4s var(--ease-out) infinite;
  }

  @keyframes hero-cue {
    0% {
      transform: scaleY(0.2);
      opacity: 0;
    }
    40% {
      opacity: 1;
    }
    100% {
      transform: scaleY(1);
      opacity: 0;
    }
  }

  /* Swap the video for the poster/gradient on small screens. */
  @container (max-width: 40rem) {
    .hero__video {
      display: none;
    }
  }

  /* Short viewports (landscape phones): drop the cue so it never overlaps. */
  @media (max-height: 540px) {
    .hero__cue {
      display: none;
    }
    .hero__inner {
      padding-block: var(--space-lg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__video {
      display: none;
    }
    .hero__cue-line {
      animation: none;
      opacity: 0.6;
    }
  }
</style>
