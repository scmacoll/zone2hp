---
// Link styled as a button. Solid (accent-deep fill, white label, AA pass) or
// outline. Mono uppercase label, near-sharp corners. Tap target >= 44px.
interface Props {
  href: string;
  variant?: 'solid' | 'outline';
  class?: string;
  [key: string]: unknown;
}

const { href, variant = 'solid', class: className = '', ...rest } = Astro.props;
---

<a href={href} class:list={['cta', `cta--${variant}`, className]} {...rest}>
  <slot />
</a>

<style>
  .cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.875rem; /* 46px tap target */
    padding-inline: var(--space-md);
    font-family: var(--font-mono);
    font-size: var(--step-label);
    font-weight: 500;
    letter-spacing: var(--track-label);
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid transparent;
    border-radius: var(--radius-sm);
    transition:
      background-color 150ms var(--ease-out),
      border-color 150ms var(--ease-out),
      color 150ms var(--ease-out);
  }

  .cta--solid {
    background: var(--accent-deep);
    color: var(--paper);
  }
  .cta--solid:hover {
    background: var(--accent-press);
  }

  .cta--outline {
    background: transparent;
    color: var(--ink);
    border-color: var(--chrome-line);
  }
  .cta--outline:hover {
    background: var(--stone);
    border-color: var(--chrome-cool);
  }
</style>
