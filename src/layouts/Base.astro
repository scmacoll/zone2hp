---
// Shared page shell: document head, self-hosted fonts, global styles,
// skip link, and the page-wide grain overlay. Concepts render their content
// into the default slot.
import '@fontsource-variable/archivo';
import '@fontsource-variable/hanken-grotesk';
import '@fontsource-variable/geist-mono';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Zone Two Health and Performance | Chiropractic & Rehab, Eastwood NSW',
  description = 'Chiropractic, post-operative rehabilitation, exercise physiology and dry needling in Eastwood, NSW. Book a first visit at Zone Two Health and Performance.',
} = Astro.props;

const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
---

<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="en_AU" />
    <meta name="theme-color" content="#FBFAF8" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <slot />
    <div class="grain" aria-hidden="true"></div>
  </body>
</html>
