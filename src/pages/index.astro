import '@fontsource-variable/archivo';
import '@fontsource-variable/hanken-grotesk';
import '@fontsource-variable/geist-mono';
import '../styles/global.css';
---

<html lang="en-AU">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Zone Two Health and Performance | Chiropractic &amp; Rehab, Eastwood NSW</title>
  </head>
  <body class="bg-paper text-ink">
    <main class="grid min-h-svh place-content-center gap-4 text-center" style="padding: var(--section-pad-inline);">
      <p class="font-mono text-ink-3" style="font-size: var(--step-label); letter-spacing: var(--track-label); text-transform: uppercase;">
        Zone Two Health &amp; Performance
      </p>
      <h1 class="font-display" style="font-size: var(--step-hero);">Opening soon in Eastwood.</h1>
      <p class="text-ink-2">Foundations wired. Components land in Phase 1.</p>
    </main>
  </body>
</html>
