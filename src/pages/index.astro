---
// Concept A2 — owner-directed iteration on A1. Same Nivis-style template,
// addressing five things at once:
//   1) Panel is genuinely translucent (0.55) with stronger backdrop-blur so the
//      video bleeds through.
//   2) Volt is brighter and less brown: --concept-volt #FF8419, hue-shifted
//      from the Nivis lime keeping its energy.
//   3) Sharper corners across the board (2-4px) per the design system.
//   4) Z² mark next to the headline keeps the mark, drops the orange circle.
//   5) EN pill loses the globe and gets two vertical dots on the right, like
//      the Quechua lookbook ":" affordance.
// Typography: Archivo replaced with Geist (variable) for display and body on
// this page only, scoped to .a2 so it doesn't leak. The mono labels stay Geist
// Mono. Closer to the Nivis / Quechua reference grotesque than Archivo was.
import Base from "../layouts/Base.astro";
import ServicesLine from "../components/ServicesLine.astro";
import MapBlock from "../components/MapBlock.astro";
import FooterExpanded from "../components/FooterExpanded.astro";
import videoSrc from "../asset/video-loop.mp4";
---

<Base>
    <div class="a2">
        <main id="main">
            <section class="a2-hero">
                <div class="a2-hero__media" aria-hidden="true">
                    <video
                        class="a2-hero__video"
                        autoplay
                        muted
                        loop
                        playsinline
                    >
                        <source src={videoSrc} type="video/mp4" />
                    </video>
                </div>

                <div class="a2-hero__chrome">
                    <header class="a2-nav">
                        <a
                            class="a2-brand reveal"
                            style="--reveal-delay: 1500ms"
                            href="#main"
                            aria-label="Zone Two Health and Performance, top of page"
                        >
                            <span class="a2-brand__mark" aria-hidden="true">
                                <svg
                                    viewBox="0 0 32 32"
                                    width="40"
                                    height="40"
                                    role="img"
                                    aria-label=""
                                >
                                    <rect
                                        width="32"
                                        height="32"
                                        rx="2"
                                        fill="#0F1013"></rect>
                                    <text
                                        x="14.5"
                                        y="22.5"
                                        text-anchor="middle"
                                        font-family="Geist Variable, Geist, system-ui, sans-serif"
                                        font-size="20"
                                        font-weight="700"
                                        letter-spacing="-0.5"
                                        fill="#FBFAF8">Z</text
                                    >
                                    <text
                                        x="25"
                                        y="13"
                                        text-anchor="middle"
                                        font-family="Geist Variable, Geist, system-ui, sans-serif"
                                        font-size="9.5"
                                        font-weight="700"
                                        fill="#FF8419">2</text
                                    >
                                </svg>
                            </span>
                            <span class="a2-brand__type">ZONE TWO</span>
                        </a>

                        <div
                            class="a2-lang-wrap reveal"
                            style="--reveal-delay: 1620ms"
                        >
                            <button
                                type="button"
                                class="a2-lang"
                                aria-label="Language: English selected"
                            >
                                <span
                                    class="a2-lang__label a2-lang__label--full"
                                    >English</span
                                >
                                <span
                                    class="a2-lang__label a2-lang__label--short"
                                    >En</span
                                >
                                <span class="a2-lang__sep" aria-hidden="true">
                                    <svg
                                        viewBox="0 0 4 14"
                                        width="6"
                                        height="21"
                                    >
                                        <circle
                                            cx="2"
                                            cy="5"
                                            r="1.2"
                                            fill="currentColor"></circle>
                                        <circle
                                            cx="2"
                                            cy="9"
                                            r="1.2"
                                            fill="currentColor"></circle>
                                    </svg>
                                </span>
                            </button>
                        </div>
                    </header>

                    <div class="a2-panel reveal" style="--reveal-delay: 1820ms">
                        <div class="a2-panel__labels">
                            <ServicesLine class="a2-services" />
                        </div>

                        <div class="a2-panel__main">
                            <h1
                                class="a2-headline reveal"
                                style="--reveal-delay: 2200ms"
                            >
                                Modern
                                <span
                                    class="a2-headline__mark"
                                    aria-hidden="true"
                                >
                                    <svg
                                        viewBox="0 0 32 32"
                                        width="32"
                                        height="32"
                                    >
                                        <rect
                                            width="32"
                                            height="32"
                                            rx="2"
                                            fill="#0F1013"></rect>
                                        <text
                                            x="14.5"
                                            y="22.5"
                                            text-anchor="middle"
                                            font-family="Geist Variable, Geist, system-ui, sans-serif"
                                            font-size="20"
                                            font-weight="700"
                                            letter-spacing="-0.5"
                                            fill="#FBFAF8">Z</text
                                        >
                                        <text
                                            x="25"
                                            y="13"
                                            text-anchor="middle"
                                            font-family="Geist Variable, Geist, system-ui, sans-serif"
                                            font-size="9.5"
                                            font-weight="700"
                                            fill="#FF8419">2</text
                                        >
                                    </svg>
                                </span><br />Chiropractic Therapy.
                            </h1>

                            <a
                                class="a2-discover reveal"
                                style="--reveal-delay: 2400ms"
                                href="#find-us"
                            >
                                <span class="a2-discover__text uppercase"
                                    >Coming<br />Soon</span
                                >
                                <span
                                    class="a2-discover__arrow"
                                    aria-hidden="true"
                                >
                                    <svg
                                        viewBox="0 0 24 24"
                                        width="18"
                                        height="18"
                                        fill="none"
                                    >
                                        <path
                                            d="M12 5v14M6 13l6 6 6-6"
                                            stroke="currentColor"
                                            stroke-width="2"
                                            stroke-linecap="round"
                                            stroke-linejoin="round"></path>
                                    </svg>
                                </span>
                            </a>
                        </div>
                    </div>
                </div>
            </section>

            <section id="find-us" class="a2-find" aria-label="Where to find us">
                <MapBlock />
            </section>
        </main>

        <FooterExpanded />
    </div>
</Base>

<style>
    /* Scope all token overrides to .a2 so they cascade into every descendant —
     reused components (ServicesLine, MapBlock, FooterExpanded) reskin without
     edits. */
    .a2 {
        /* Volt (hue-shifted from Nivis lime, same saturation + brightness). */
        --concept-volt: #ff8419;
        --concept-volt-press: #e66a0f;

        /* Hero grade fallback when no real video is present. */
        --grad-hero: var(--grad-hero-a1);

        /* Typography swap. Geist for display and body, mono untouched. */
        --font-display: "Geist Variable", Geist, system-ui, sans-serif;
        --font-body: "Geist Variable", Geist, system-ui, sans-serif;

        /* Sharper corners across the page (was 10-14px on A1). */
        --r-sharp: 2px;
        --m-soft: 8px;
        --r-soft: 6px;
    }

    /* ---- Hero ---------------------------------------------------------------- */
    .a2-hero {
        position: relative;
        min-height: 100vh;
        min-height: 100svh;
        overflow: clip;
        isolation: isolate;
    }
    .a2-hero__media {
        position: absolute;
        inset: 0;
        z-index: 0;
        background: var(--grad-hero);
    }
    .a2-hero__video {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        /* Cinema reveal: starts as a cropped box (set by --cinema-from), eases
           out to full screen, then holds. The from-state is a CSS variable so
           media queries can change it (landscape vs portrait) WITHOUT swapping
           animation-name — swapping animation-name restarts the animation on
           every resize across the breakpoint. With fill-mode: both, once the
           animation completes the element holds inset(0) and changing the
           variable has no visible effect (so resize is safe). */
        --cinema-from: inset(
            38% 0% 38% 0%
        ); /* landscape: horizontal letterbox */
        animation: a2-hero-cinema 1000ms cubic-bezier(0.65, 0, 0.35, 1) both;
        will-change: clip-path;
    }

    @keyframes a2-hero-cinema {
        from {
            clip-path: var(--cinema-from);
        }
        to {
            clip-path: inset(0% 0% 0% 0%);
        }
    }

    .a2-hero__chrome {
        position: relative;
        z-index: 1;
        min-height: inherit;
        display: flex;
        flex-direction: column;
        gap: var(--space-md);
        padding: 2.66rem 1.33rem 1.33rem;
        transition: padding 350ms var(--ease-out);
    }
    /* At half-browser (~848px = 53rem) the panel's max-width (48rem) starts
       leaving a 40px gap to each viewport edge. Lift the chrome's side padding
       to 2.5rem (40px) at and above this threshold so the nav keeps the SAME
       40px gap as that point at every wider viewport. Below half-browser the
       chrome stays at 1.33rem so mobile doesn't waste space. The nav itself
       just fills the chrome content area (no max-width / margin-auto), so at
       wider viewports the header is genuinely wider than the panel while both
       align at exactly half-browser. */
    @media (min-width: 53rem) {
        .a2-hero__chrome {
            padding: 2.66rem 2.5rem 1.33rem;
        }
    }

    /* ---- Top bar: logo left, EN pill right ----------------------------------- */
    .a2-nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-sm);
        width: 100%;
        /* Smooth the snap when the translucent strip fades in/out around 47rem. */
        transition:
            background-color 350ms var(--ease-out),
            border-color 350ms var(--ease-out),
            padding 350ms var(--ease-out),
            -webkit-backdrop-filter 350ms var(--ease-out),
            backdrop-filter 350ms var(--ease-out);
    }
    .a2-brand {
        display: inline-flex;
        align-items: center;
        gap: 0.65rem;
        text-decoration: none;
        color: var(--ink);
    }
    .a2-brand__mark {
        display: inline-flex;
        width: clamp(36px, 3vw + 28px, 44px);
        height: clamp(36px, 3vw + 28px, 44px);
    }
    .a2-brand__mark svg {
        width: 100%;
        height: 100%;
        border-radius: var(--r-sharp);
    }
    .a2-brand__type {
        font-family: var(--font-display);
        font-weight: 700;
        font-size: clamp(0.95rem, 0.85rem + 0.3vw, 1.05rem);
        letter-spacing: 0.02em;
        text-transform: uppercase;
        color: var(--paper);
    }

    .a2-lang {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        min-height: 44px;
        padding: 0 0.85rem;
        background: var(--concept-volt);
        color: var(--ink);
        border: 0;
        border-radius: var(--r-soft);
        font-family: var(--font-display);
        font-size: 0.95rem;
        font-weight: 600;
        letter-spacing: -0.005em;
        cursor: pointer;
        transition: background-color 150ms var(--ease-out);
    }
    .a2-lang:hover {
        background: var(--concept-volt-press);
    }
    .a2-lang__label {
        line-height: 1;
    }
    .a2-lang__sep {
        display: inline-flex;
        align-items: center;
        color: var(--ink);
        opacity: 0.7;
    }

    .a2-lang-wrap {
        padding: 0.3rem;
        background: rgba(15, 16, 19, 0.35);
        border-radius: var(--m-soft);
        -webkit-backdrop-filter: blur(16px) saturate(120%);
        backdrop-filter: blur(16px) saturate(120%);
        /* Smooth fade as this box dissolves into the parent nav strip at <47rem. */
        transition:
            background-color 350ms var(--ease-out),
            padding 350ms var(--ease-out),
            -webkit-backdrop-filter 350ms var(--ease-out),
            backdrop-filter 350ms var(--ease-out);
    }
    .a2-lang__label--short {
        display: none;
    }
    .a2-lang__label--full {
        display: inline;
    }
    @media (max-width: 47rem) {
        .a2-lang__label--full {
            display: none;
        }
        .a2-lang__label--short {
            display: inline;
        }
    }

    /* ---- Dark, MORE translucent panel ---------------------------------------- */
    .a2-panel {
        container-type: inline-size;
        margin-top: auto;
        width: 100%;
        max-width: 48rem;
        min-height: 20rem;
        margin-inline: auto;
        display: flex; /* ADD */
        flex-direction: column; /* ADD */
        --ink-2: rgba(255, 255, 255, 0.7);
        --accent: var(--concept-volt);
        padding: clamp(1.25rem, 1rem + 1.4vw, 2rem);
        background: rgba(15, 16, 19, 0.55);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: var(--m-soft);
        -webkit-backdrop-filter: blur(16px) saturate(120%);
        backdrop-filter: blur(16px) saturate(120%);
        color: var(--paper);
        /* Smooth padding shrink at the mobile breakpoint. */
        transition: padding 350ms var(--ease-out);
    }
    .a2-panel__labels {
        padding-bottom: var(--space-sm);
        border-bottom: 1px solid rgba(255, 255, 255, 0.16);
    }
    .a2-panel :global(.a2-services) {
        font-size: var(--step-label);
    }

    .a2-panel.reveal {
        transform: translateY(70%);
        animation-duration: 1100ms;
    }

    .a2-panel__main {
        display: flex;
        flex-direction: column;
        gap: var(--space-md);
        padding-top: var(--space-md);
        margin-top: auto; /* ADD */
    }
    @container (min-width: 34rem) {
        .a2-panel__main {
            flex-direction: row;
            align-items: flex-end;
            justify-content: space-between;
            gap: var(--space-lg);
        }
    }

    /* Geist tuned for the headline: medium-bold, tight tracking, near-1 leading.
     Replaces Archivo 800 expanded which was too inflated. */
    .a2-headline {
        margin: 0;
        font-family: var(--font-display);
        font-weight: 600;
        /*font-size: clamp(2.5rem, 1.4rem + 4.4vw, 4.75rem);*/
        font-size: clamp(2rem, 1.15rem + 3.4vw, 3.75rem);
        /*font-size: clamp(1.5rem, 0.9rem + 2.4vw, 2.75rem);*/
        line-height: 0.96;
        letter-spacing: -0.025em;
        color: var(--paper);
    }
    /* Z² mark inline, no orange backdrop. Just the volt on the 2 to keep the
     accent without the cartoony chip. */
    /*.a2-headline__mark {
        display: inline-block;
        margin-left: 0.18em;
        font-size: 0.32em;
        font-weight: 700;
        line-height: 1;
        letter-spacing: 0;
        vertical-align: 0.95em;
        color: var(--paper);
    }*/
    .a2-headline__mark {
        display: inline-block;
        width: 0.65em;
        height: 0.65em;
        margin: 0 -0.12em;
        vertical-align: 0.4em;
    }
    .a2-headline__mark svg {
        width: 100%;
        height: 100%;
        border-radius: 2px;
    }
    .a2-headline__mark sup {
        color: var(--concept-volt);
        font-size: 0.8em;
        vertical-align: super;
        line-height: 0;
        margin-left: 0.04em;
    }

    /* ---- Discover CTA -------------------------------------------------------- */
    .a2-discover {
        flex: none;
        display: inline-flex;
        align-items: center;
        gap: var(--space-sm);
        min-height: 44px;
        align-self: flex-start;
        padding: 0.8rem 1.05rem;
        background: var(--concept-volt);
        color: var(--ink);
        border-radius: var(--r-soft);
        text-decoration: none;
        font-family: var(--font-display);
        font-size: 0.9rem;
        font-weight: 600;
        letter-spacing: -0.005em;
        line-height: 1.2;
        transition:
            background-color 150ms var(--ease-out),
            padding 350ms var(--ease-out);
    }
    .a2-discover:hover {
        background: var(--concept-volt-press);
    }
    @container (min-width: 34rem) {
        .a2-discover {
            align-self: flex-end;
        }
    }
    .a2-discover__arrow {
        display: inline-flex;
    }

    /* ---- Find-us (map) section ---------------------------------------------- */
    .a2-find {
        max-width: var(--container-max);
        margin-inline: auto;
        padding-block: var(--section-pad-block);
        padding-inline: var(--section-pad-inline);
    }

    /* ---- Mobile / half-laptop reshuffle (matches the Nivis breakpoint) ------
       Below 47rem (~752px) — measured from nivisgear.com: the entire nav
       becomes the dark translucent strip (the lang button's own wrap goes
       transparent so we don't double-box); the panel padding tightens; the
       discover CTA stretches to the full panel width with the arrow pushed
       to the right; the services line lays out in a clean 2x2 grid with the
       separator dots hidden. Above 47rem reverts to the desktop layout above.
       Transitions on the affected elements make the snap feel like a slide
       when the browser is drag-resized across the breakpoint. */
    @media (max-width: 47rem) {
        .a2-nav {
            background: rgba(15, 16, 19, 0.55);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: var(--m-soft);
            padding: 0.35rem 0.35rem 0.35rem 0.6rem;
            -webkit-backdrop-filter: blur(16px) saturate(120%);
            backdrop-filter: blur(16px) saturate(120%);
        }
        .a2-lang-wrap {
            background: transparent;
            border: 0;
            padding: 0;
            -webkit-backdrop-filter: none;
            backdrop-filter: none;
        }
        .a2-panel {
            padding: 0.75rem;
            min-height: 18rem;
        }
        /* Portrait reveal start: a centred ~2:3 box (cropped on all four sides)
           that eases out to full-screen. Updating just the variable, not the
           animation-name, prevents the reveal from replaying when the user
           drags across the breakpoint. */
        .a2-hero__video {
            --cinema-from: inset(22% 25% 22% 25%);
        }
        /* Force the headline/CTA stack to stay vertical at mobile/half-laptop
           even when the panel's own container query would otherwise make it a
           row at >= 34rem panel width. CTA stretches full width of the panel. */
        .a2-panel__main {
            flex-direction: column;
            align-items: stretch;
        }
        .a2-discover {
            width: 100%;
            align-self: stretch;
            justify-content: space-between;
            padding: 1rem 1.05rem;
        }
        .a2-panel :global(.a2-services) {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.55rem 1rem;
        }
        .a2-panel :global(.a2-services .services__sep) {
            display: none;
        }
    }

    /* Video now plays at every viewport (the small-screen hide rule was
       removed). Reduced-motion still skips the cinema reveal. */
    @media (prefers-reduced-motion: reduce) {
        .a2-hero__video {
            display: none;
            animation: none;
            clip-path: inset(0);
        }
    }
</style>
