---
// Phase 1 system demo: composes the shared layout and components with the real
// copy bank so the test-width screenshots read well. This page is scaffolding;
// the winning concept replaces it in a later phase.
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import Wordmark from '../components/Wordmark.astro';
import Eyebrow from '../components/Eyebrow.astro';
import ServicesLine from '../components/ServicesLine.astro';
import MapBlock from '../components/MapBlock.astro';
import ContactBlock from '../components/ContactBlock.astro';
import Footer from '../components/Footer.astro';
---

<Base>
  <main id="main">
    <Hero scrollCue>
      <Eyebrow class="reveal" style="--reveal-delay: 0ms">Zone Two Health &amp; Performance</Eyebrow>
      <Wordmark as="div" size="lg" class="reveal" style="--reveal-delay: 90ms" />
      <h1 class="hero__headline reveal" style="--reveal-delay: 180ms">Opening soon in Eastwood.</h1>
      <p class="hero__sub reveal" style="--reveal-delay: 270ms">
        Chiropractic, post-operative rehabilitation, exercise physiology and dry needling.
      </p>
      <ServicesLine class="reveal" style="--reveal-delay: 360ms" />
    </Hero>

    <section class="info" aria-label="Location and contact">
      <p class="info__arc">Recover. Rebuild. Perform.</p>
      <div class="info__blocks">
        <MapBlock />
        <ContactBlock />
      </div>
    </section>
  </main>

  <Footer />
</Base>

<style>
  .hero__headline {
    font-size: var(--step-hero);
    max-width: 16ch;
  }
  .hero__sub {
    max-width: 46ch;
    font-size: var(--step-h3);
    color: var(--ink-2);
  }

  .info {
    container-type: inline-size;
    max-width: var(--container-max);
    margin-inline: auto;
    padding-block: var(--section-pad-block);
    padding-inline: var(--section-pad-inline);
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .info__arc {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--step-h2);
    letter-spacing: var(--track-tight);
    color: var(--ink);
  }

  .info__blocks {
    display: grid;
    gap: var(--space-xl) var(--space-lg);
  }
  @container (min-width: 60rem) {
    .info__blocks {
      grid-template-columns: 1.4fr 1fr;
      align-items: start;
    }
  }
</style>
