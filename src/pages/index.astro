---
// Concept A2 — owner-directed iteration on A1. Same Nivis-style template,
// addressing five things at once:
//   1) Panel is genuinely translucent (0.55) with stronger backdrop-blur so the
//      video bleeds through.
//   2) Volt is brighter and less brown: --concept-volt #FF8419, hue-shifted
//      from the Nivis lime keeping its energy.
//   3) Sharper corners across the board (2-4px) per the design system.
//   4) Z² mark next to the headline keeps the mark, drops the orange circle.
//   5) EN pill loses the globe and gets two vertical dots on the right, like
//      the Quechua lookbook ":" affordance.
// Typography: Archivo replaced with Geist (variable) for display and body on
// this page only, scoped to .a2 so it doesn't leak. The mono labels stay Geist
// Mono. Closer to the Nivis / Quechua reference grotesque than Archivo was.
import Base from "../layouts/Base.astro";
import ServicesLine from "../components/ServicesLine.astro";
import MapBlock from "../components/MapBlock.astro";
import FooterExpanded from "../components/FooterExpanded.astro";
import { bookingConfig } from "../lib/booking/config";
// import videoSrc from "../asset/video-loop.mp4";
import videoSrc from "../asset/zone2hp-video-loop-final.mp4";

// Owner asked for a single account button + a Book now CTA in the nav. Gated by
// the same flag that surfaces public booking/account links (now on by default).
const showLinks = bookingConfig.linksVisible;
---

<Base>
    <div class="a2">
        <main id="main">
            <section class="a2-hero">
                <div class="a2-hero__media" aria-hidden="true">
                    <video
                        class="a2-hero__video"
                        autoplay
                        muted
                        loop
                        playsinline
                    >
                        <source src={videoSrc} type="video/mp4" />
                    </video>
                </div>

                <div class="a2-hero__chrome">
                    <header class="a2-nav">
                        <a
                            class="a2-brand reveal"
                            style="--reveal-delay: 1500ms"
                            href="#main"
                            aria-label="Zone Two Health and Performance, top of page"
                        >
                            <span class="a2-brand__mark" aria-hidden="true">
                                <svg
                                    viewBox="0 0 32 32"
                                    width="40"
                                    height="40"
                                    role="img"
                                    aria-label=""
                                >
                                    <rect
                                        width="32"
                                        height="32"
                                        rx="2"
                                        fill="#0F1013"></rect>
                                    <text
                                        x="14.5"
                                        y="22.5"
                                        text-anchor="middle"
                                        font-family="Geist Variable, Geist, system-ui, sans-serif"
                                        font-size="20"
                                        font-weight="700"
                                        letter-spacing="-0.5"
                                        fill="#FBFAF8">Z</text
                                    >
                                    <text
                                        x="25"
                                        y="13"
                                        text-anchor="middle"
                                        font-family="Geist Variable, Geist, system-ui, sans-serif"
                                        font-size="9.5"
                                        font-weight="700"
                                        fill="#FF8419">2</text
                                    >
                                </svg>
                            </span>
                            <span class="a2-brand__type">ZONE TWO</span>
                        </a>

                        <div class="a2-actions">
                            <div
                            class="a2-lang-wrap reveal"
                            style="--reveal-delay: 1620ms"
                            data-lang-current="en"
                        >
                            <button
                                type="button"
                                class="a2-lang"
                                aria-label="Language: English"
                            >
                                <span
                                    class="a2-lang__label a2-lang__label--full"
                                    >English</span
                                >
                                <span
                                    class="a2-lang__label a2-lang__label--short"
                                    >En</span
                                >
                                <span class="a2-lang__sep" aria-hidden="true">
                                    <svg
                                        viewBox="0 0 4 14"
                                        width="6"
                                        height="21"
                                    >
                                        <circle
                                            cx="2"
                                            cy="5"
                                            r="1.2"
                                            fill="currentColor"></circle>
                                        <circle
                                            cx="2"
                                            cy="9"
                                            r="1.2"
                                            fill="currentColor"></circle>
                                    </svg>
                                </span>
                            </button>

                            {
                                /* Korean dropdown paused for now — markup kept so
                            we can re-enable when translation copy is ready. */
                            }
                            <ul
                                class="a2-lang__menu"
                                role="listbox"
                                aria-label="Language"
                                hidden
                            >
                                <li role="option" aria-selected="false">
                                    <button
                                        type="button"
                                        class="a2-lang__option"
                                        data-lang="ko">Korean</button
                                    >
                                </li>
                            </ul>
                            </div>

                            {
                                showLinks && (
                                    <div class="a2-cta-group">
                                        <a
                                            class="a2-login reveal"
                                            style="--reveal-delay: 1700ms"
                                            href="/account/login"
                                            aria-label="Log in or create an account"
                                        >
                                            <svg
                                                class="a2-login__icon"
                                                viewBox="0 0 24 24"
                                                fill="none"
                                                aria-hidden="true"
                                            >
                                                <circle
                                                    cx="12"
                                                    cy="8.5"
                                                    r="3.5"
                                                    stroke="currentColor"
                                                    stroke-width="2"
                                                />
                                                <path
                                                    d="M5 20c0-3.6 3.1-6 7-6s7 2.4 7 6"
                                                    stroke="currentColor"
                                                    stroke-width="2"
                                                    stroke-linecap="round"
                                                />
                                            </svg>
                                            <span class="a2-login__label">Log in</span>
                                        </a>
                                        <a
                                            class="a2-book reveal"
                                            style="--reveal-delay: 1780ms"
                                            href="/book"
                                        >
                                            <span class="a2-book__full">Book now</span>
                                            <span class="a2-book__short">Book</span>
                                        </a>
                                    </div>
                                )
                            }
                        </div>
                    </header>

                    <div class="a2-panel reveal" style="--reveal-delay: 1820ms">
                        <div class="a2-panel__labels">
                            <ServicesLine class="a2-services" />
                        </div>

                        <div class="a2-panel__main">
                            <h1
                                class="a2-headline reveal"
                                style="--reveal-delay: 2200ms"
                            >
                                Modern
                                <span
                                    class="a2-headline__mark"
                                    aria-hidden="true"
                                >
                                    <svg
                                        viewBox="0 0 32 32"
                                        width="32"
                                        height="32"
                                    >
                                        <rect
                                            width="32"
                                            height="32"
                                            rx="2"
                                            fill="#0F1013"></rect>
                                        <text
                                            x="14.5"
                                            y="22.5"
                                            text-anchor="middle"
                                            font-family="Geist Variable, Geist, system-ui, sans-serif"
                                            font-size="20"
                                            font-weight="700"
                                            letter-spacing="-0.5"
                                            fill="#FBFAF8">Z</text
                                        >
                                        <text
                                            x="25"
                                            y="13"
                                            text-anchor="middle"
                                            font-family="Geist Variable, Geist, system-ui, sans-serif"
                                            font-size="9.5"
                                            font-weight="700"
                                            fill="#FF8419">2</text
                                        >
                                    </svg>
                                </span><br />Chiropractic Therapy.
                            </h1>

                            <a
                                class="a2-discover reveal"
                                style="--reveal-delay: 2400ms"
                                href="#find-us"
                            >
                                <span class="a2-discover__text uppercase"
                                    >Coming<br />Soon</span
                                >
                                <span
                                    class="a2-discover__arrow"
                                    aria-hidden="true"
                                >
                                    <svg
                                        viewBox="0 0 24 24"
                                        width="18"
                                        height="18"
                                        fill="none"
                                    >
                                        <path
                                            d="M12 5v14M6 13l6 6 6-6"
                                            stroke="currentColor"
                                            stroke-width="2"
                                            stroke-linecap="round"
                                            stroke-linejoin="round"></path>
                                    </svg>
                                </span>
                            </a>
                        </div>
                    </div>
                </div>
            </section>

            <section id="find-us" class="a2-find" aria-label="Where to find us">
                <MapBlock />
            </section>
        </main>

        <FooterExpanded />
    </div>
</Base>

<style>
    /* Scope all token overrides to .a2 so they cascade into every descendant —
     reused components (ServicesLine, MapBlock, FooterExpanded) reskin without
     edits. */
    .a2 {
        /* Volt (hue-shifted from Nivis lime, same saturation + brightness). */
        --concept-volt: #ff8419;
        --concept-volt-press: #e66a0f;

        /* Hero grade fallback when no real video is present. */
        --grad-hero: var(--grad-hero-a1);

        /* Typography swap. Geist for display and body, mono untouched. */
        --font-display: "Geist Variable", Geist, system-ui, sans-serif;
        --font-body: "Geist Variable", Geist, system-ui, sans-serif;

        /* Sharper corners across the page (was 10-14px on A1). */
        --r-sharp: 2px;
        --m-soft: 8px;
        --r-soft: 6px;
    }

    /* ---- Hero ---------------------------------------------------------------- */
    .a2-hero {
        position: relative;
        min-height: 100vh;
        min-height: 100svh;
        overflow: clip;
        isolation: isolate;
    }
    .a2-hero__media {
        position: absolute;
        inset: 0;
        z-index: 0;
        background: var(--grad-hero);
    }
    .a2-hero__video {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        /* TEMP — heavy blur on the stock video while sharing with the owner so
           the licensed footage isn't recognisable. Scaled up slightly so the
           blur radius doesn't reveal transparent edges. Delete `filter` and
           `transform` to restore the real footage. */
        /*filter: blur(12px) saturate(115%);*/
        /*transform: scale(-1.15, 1.15);*/
        /* Cinema reveal: starts as a cropped box (set by --cinema-from), eases
           out to full screen, then holds. The from-state is a CSS variable so
           media queries can change it (landscape vs portrait) WITHOUT swapping
           animation-name — swapping animation-name restarts the animation on
           every resize across the breakpoint. With fill-mode: both, once the
           animation completes the element holds inset(0) and changing the
           variable has no visible effect (so resize is safe). */
        --cinema-from: inset(
            30% 14% 30% 14% round 18px
        ); /* landscape: wider cinema box (~2.9-3.4:1 on 16:10/9 displays), soft corners */
        animation: a2-hero-cinema 1000ms cubic-bezier(0.65, 0, 0.35, 1) both;
        will-change: clip-path;
    }

    @keyframes a2-hero-cinema {
        from {
            clip-path: var(--cinema-from);
        }
        to {
            clip-path: inset(0% 0% 0% 0% round 0);
        }
    }

    /* Mobile navbar background fade-in (<=47rem only). The translucent strip
       behind the nav used to be visible from page-load 0ms — beating the
       chrome reveals (brand at 1500ms, etc) to the screen. This keyframe
       starts transparent + no-blur, eases to its final translucent state at
       the same 1500ms mark the brand starts revealing, so the strip appears
       AS PART OF the chrome reveal sequence rather than before it. */
    @keyframes a2-navbar-reveal {
        from {
            background-color: transparent;
            border-color: transparent;
            -webkit-backdrop-filter: blur(0) saturate(100%);
            backdrop-filter: blur(0) saturate(100%);
        }
        to {
            background-color: rgba(15, 16, 19, 0.55);
            border-color: rgba(255, 255, 255, 0.08);
            -webkit-backdrop-filter: blur(16px) saturate(120%);
            backdrop-filter: blur(16px) saturate(120%);
        }
    }

    .a2-hero__chrome {
        position: relative;
        z-index: 1;
        min-height: inherit;
        display: flex;
        flex-direction: column;
        gap: var(--space-md);
        padding: 2.66rem 1.33rem 1.33rem;
        transition: padding 350ms var(--ease-out);
    }
    /* At half-browser (~848px = 53rem) the panel's max-width (48rem) starts
       leaving a 40px gap to each viewport edge. Lift the chrome's side padding
       to 2.5rem (40px) at and above this threshold so the nav keeps the SAME
       40px gap as that point at every wider viewport. Below half-browser the
       chrome stays at 1.33rem so mobile doesn't waste space. The nav itself
       just fills the chrome content area (no max-width / margin-auto), so at
       wider viewports the header is genuinely wider than the panel while both
       align at exactly half-browser. */
    @media (min-width: 53rem) {
        .a2-hero__chrome {
            padding: 2.66rem 2.5rem 1.33rem;
        }
    }

    /* ---- Top bar: logo left, EN pill right -----------------------------------
       Only padding has a transition. The bg/border/backdrop are intentionally
       NOT transitioned — they appear/disappear in a single frame whenever the
       @media breakpoint flips. Transitioning them caused a perceived
       "background and outline arrive at different times" flicker during
       drag-resize because each property repaints on its own pass. */
    .a2-nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-sm);
        width: 100%;
        transition: padding 350ms var(--ease-out);
    }
    .a2-brand {
        display: inline-flex;
        align-items: center;
        gap: 0.65rem;
        text-decoration: none;
        color: var(--ink);
    }
    .a2-brand__mark {
        display: inline-flex;
        width: clamp(36px, 3vw + 28px, 44px);
        height: clamp(36px, 3vw + 28px, 44px);
    }
    .a2-brand__mark svg {
        width: 100%;
        height: 100%;
        border-radius: var(--r-sharp);
    }
    .a2-brand__type {
        font-family: var(--font-display);
        font-weight: 700;
        font-size: clamp(0.95rem, 0.85rem + 0.3vw, 1.05rem);
        letter-spacing: 0.02em;
        text-transform: uppercase;
        color: var(--paper);
    }

    /* Language: a small, light TEXT toggle (no fill) so it reads as a quiet
       utility, not a button competing with the action pair. */
    .a2-lang {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        min-height: 40px;
        padding: 0 0.25rem;
        background: transparent;
        color: var(--paper);
        border: 0;
        font-family: var(--font-display);
        font-size: 0.82rem;
        font-weight: 500;
        letter-spacing: 0.01em;
        cursor: pointer;
        transition: color 150ms var(--ease-out);
    }
    .a2-lang:hover {
        color: var(--concept-volt);
    }
    .a2-lang__label {
        line-height: 1;
    }
    .a2-lang__sep {
        display: inline-flex;
        align-items: center;
        color: currentColor;
        opacity: 0.55;
    }

    .a2-lang-wrap {
        position: relative;
    }

    /* ---- Nav actions: account + book CTA (owner request) -------------------
       Synthesised from the references: one outlined secondary control (Log in,
       like the Nivis CART box) and one volt-filled primary CTA (Book now, like
       the Nivis SHOP box / Myo BOOK NOW). Both read on the dark video hero. */
    .a2-actions {
        display: flex;
        align-items: center;
        gap: 0.9rem;
    }
    /* The action pair (Log in + Book now) grouped tighter, separated from the
       quiet language toggle to its left. */
    .a2-cta-group {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .a2-login {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        min-height: 44px;
        padding: 0 0.9rem;
        border: 1px solid rgba(255, 255, 255, 0.55);
        border-radius: var(--r-soft);
        background: rgba(15, 16, 19, 0.28);
        color: var(--paper);
        text-decoration: none;
        font-family: var(--font-display);
        font-size: 0.95rem;
        font-weight: 600;
        letter-spacing: -0.005em;
        -webkit-backdrop-filter: blur(12px) saturate(120%);
        backdrop-filter: blur(12px) saturate(120%);
        transition:
            background-color 150ms var(--ease-out),
            border-color 150ms var(--ease-out);
    }
    .a2-login:hover {
        background: rgba(15, 16, 19, 0.45);
        border-color: rgba(255, 255, 255, 0.85);
    }
    .a2-login__icon {
        width: 18px;
        height: 18px;
        flex: none;
    }
    .a2-book {
        display: inline-flex;
        align-items: center;
        min-height: 44px;
        padding: 0 1.15rem;
        background: var(--concept-volt);
        color: var(--ink);
        border-radius: var(--r-soft);
        text-decoration: none;
        font-family: var(--font-display);
        font-size: 0.95rem;
        font-weight: 600;
        letter-spacing: -0.005em;
        transition: background-color 150ms var(--ease-out);
    }
    .a2-book:hover {
        background: var(--concept-volt-press);
    }
    .a2-book__short {
        display: none;
    }

    /* ---- Language dropdown menu --------------------------------------------
       Hidden by default; opens below the orange En/English button when the
       user clicks it. Style mirrors the panel + lang-wrap: translucent dark
       surface, backdrop-blur, soft corners. The orange button stays the
       "currently selected" affordance — the menu only lists alternatives. */
    .a2-lang__menu {
        position: absolute;
        top: calc(100% + 0.5rem);
        right: 0;
        min-width: 10rem;
        margin: 0;
        padding: 0.35rem;
        list-style: none;
        background: rgba(15, 16, 19, 0.65);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: var(--m-soft);
        -webkit-backdrop-filter: blur(20px) saturate(120%);
        backdrop-filter: blur(20px) saturate(120%);
        opacity: 0;
        transform: translateY(-0.4rem);
        visibility: hidden;
        pointer-events: none;
        transition:
            opacity 200ms var(--ease-out),
            transform 200ms var(--ease-out),
            visibility 0s linear 200ms;
        z-index: 5;
    }
    .a2-lang-wrap[data-open="true"] .a2-lang__menu {
        opacity: 1;
        transform: none;
        visibility: visible;
        pointer-events: auto;
        transition:
            opacity 200ms var(--ease-out),
            transform 200ms var(--ease-out),
            visibility 0s linear;
    }

    .a2-lang__option {
        display: block;
        width: 100%;
        min-height: 44px;
        padding: 0.55rem 0.85rem;
        background: transparent;
        color: var(--paper);
        border: 0;
        border-radius: 4px;
        font-family: var(--font-display);
        font-size: 0.95rem;
        font-weight: 500;
        text-align: left;
        cursor: pointer;
        transition: background-color 150ms var(--ease-out);
    }
    .a2-lang__option:hover,
    .a2-lang__option:focus-visible {
        background: rgba(255, 255, 255, 0.08);
        outline: none;
    }
    .a2-lang__label--short {
        display: none;
    }
    .a2-lang__label--full {
        display: inline;
    }
    @media (max-width: 47rem) {
        .a2-lang__label--full {
            display: none;
        }
        .a2-lang__label--short {
            display: inline;
        }
    }

    /* ---- Dark, MORE translucent panel ---------------------------------------- */
    .a2-panel {
        container-type: inline-size;
        margin-top: auto;
        width: 100%;
        max-width: 48rem;
        min-height: 20rem;
        margin-inline: auto;
        display: flex; /* ADD */
        flex-direction: column; /* ADD */
        --ink-2: rgba(255, 255, 255, 0.7);
        --accent: var(--concept-volt);
        padding: clamp(1.25rem, 1rem + 1.4vw, 2rem);
        background: rgba(15, 16, 19, 0.55);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: var(--m-soft);
        -webkit-backdrop-filter: blur(16px) saturate(120%);
        backdrop-filter: blur(16px) saturate(120%);
        color: var(--paper);
        /* Smooth padding shrink at the mobile breakpoint. */
        transition: padding 350ms var(--ease-out);
    }
    .a2-panel__labels {
        padding-bottom: var(--space-sm);
        border-bottom: 1px solid rgba(255, 255, 255, 0.16);
    }
    .a2-panel :global(.a2-services) {
        font-size: var(--step-label);
    }

    .a2-panel.reveal {
        transform: translateY(70%);
        animation-duration: 1100ms;
    }

    .a2-panel__main {
        display: flex;
        flex-direction: column;
        gap: var(--space-md);
        padding-top: var(--space-md);
        margin-top: auto; /* ADD */
    }
    @container (min-width: 34rem) {
        .a2-panel__main {
            flex-direction: row;
            align-items: flex-end;
            justify-content: space-between;
            gap: var(--space-lg);
        }
    }

    /* Geist tuned for the headline: medium-bold, tight tracking, near-1 leading.
     Replaces Archivo 800 expanded which was too inflated. */
    .a2-headline {
        margin: 0;
        font-family: var(--font-display);
        font-weight: 600;
        /*font-size: clamp(2.5rem, 1.4rem + 4.4vw, 4.75rem);*/
        font-size: clamp(2rem, 1.15rem + 3.4vw, 3.75rem);
        /*font-size: clamp(1.5rem, 0.9rem + 2.4vw, 2.75rem);*/
        line-height: 0.96;
        letter-spacing: -0.025em;
        color: var(--paper);
    }
    /* Z² mark inline, no orange backdrop. Just the volt on the 2 to keep the
     accent without the cartoony chip. */
    /*.a2-headline__mark {
        display: inline-block;
        margin-left: 0.18em;
        font-size: 0.32em;
        font-weight: 700;
        line-height: 1;
        letter-spacing: 0;
        vertical-align: 0.95em;
        color: var(--paper);
    }*/
    .a2-headline__mark {
        display: inline-block;
        width: 0.65em;
        height: 0.65em;
        margin: 0 -0.12em;
        vertical-align: 0.4em;
    }
    .a2-headline__mark svg {
        width: 100%;
        height: 100%;
        border-radius: 2px;
    }
    .a2-headline__mark sup {
        color: var(--concept-volt);
        font-size: 0.8em;
        vertical-align: super;
        line-height: 0;
        margin-left: 0.04em;
    }

    /* ---- Discover CTA -------------------------------------------------------- */
    .a2-discover {
        flex: none;
        display: inline-flex;
        align-items: center;
        gap: var(--space-sm);
        min-height: 44px;
        align-self: flex-start;
        padding: 0.8rem 1.05rem;
        background: var(--concept-volt);
        color: var(--ink);
        border-radius: var(--r-soft);
        text-decoration: none;
        font-family: var(--font-display);
        font-size: 0.9rem;
        font-weight: 600;
        letter-spacing: -0.005em;
        line-height: 1.2;
        transition:
            background-color 150ms var(--ease-out),
            padding 350ms var(--ease-out);
    }
    .a2-discover:hover {
        background: var(--concept-volt-press);
    }
    @container (min-width: 34rem) {
        .a2-discover {
            align-self: flex-end;
        }
    }
    .a2-discover__arrow {
        display: inline-flex;
    }

    /* ---- Find-us (map) section ---------------------------------------------- */
    .a2-find {
        max-width: var(--container-max);
        margin-inline: auto;
        padding-block: var(--section-pad-block);
        padding-inline: var(--section-pad-inline);
    }

    /* At mobile + half-laptop the MapBlock stacks (map on top, details below).
       By default the details are left-aligned and create a sparse left-leaning
       block with lots of empty space on the right. Centring the eyebrow, h2,
       address and the "Open in Google Maps" link gives the stack a balanced
       postcard look that mirrors the panel/footer treatment elsewhere. */
    @media (max-width: 47rem) {
        .a2-find :global(.map__details) {
            align-items: center;
            text-align: center;
        }
        .a2-find :global(.map__link) {
            align-self: center;
        }
    }

    /* ---- Mobile / half-laptop reshuffle (matches the Nivis breakpoint) ------
       Below 47rem (~752px) — measured from nivisgear.com: the entire nav
       becomes the dark translucent strip (the lang button's own wrap goes
       transparent so we don't double-box); the panel padding tightens; the
       discover CTA stretches to the full panel width with the arrow pushed
       to the right; the services line lays out in a clean 2x2 grid with the
       separator dots hidden. Above 47rem reverts to the desktop layout above.
       Transitions on the affected elements make the snap feel like a slide
       when the browser is drag-resized across the breakpoint. */
    @media (max-width: 47rem) {
        .a2-nav {
            padding: 0.35rem 0.35rem 0.35rem 0.6rem;
            background: rgba(15, 16, 19, 0.55);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: var(--m-soft);
            -webkit-backdrop-filter: blur(16px) saturate(120%);
            backdrop-filter: blur(16px) saturate(120%);
        }
        /* Only run the reveal animation on initial page load. Once .a2.is-revealed
           lands (~2.5s after load via the script), the animation no longer
           applies — any later resize across the breakpoint just snaps the strip
           on/off in a single frame via the @media rule above, no 1.5s delay
           replay, no per-property flicker. */
        .a2:not(.is-revealed) .a2-nav {
            animation: a2-navbar-reveal var(--reveal-duration, 700ms)
                var(--ease-out) 1500ms both;
        }
        .a2-lang-wrap {
            background: transparent;
            border: 0;
            padding: 0;
            -webkit-backdrop-filter: none;
            backdrop-filter: none;
        }
        /* Tighten the action cluster on the mobile strip: Log in shows text only
           (no icon), Book now shortens to "Book". */
        .a2-actions {
            gap: 0.5rem;
        }
        .a2-cta-group {
            gap: 0.4rem;
        }
        .a2-login {
            padding: 0 0.75rem;
            gap: 0;
        }
        .a2-login__icon {
            display: none;
        }
        .a2-book {
            padding: 0 0.85rem;
        }
        .a2-book__full {
            display: none;
        }
        .a2-book__short {
            display: inline;
        }
        .a2-panel {
            padding: 0.75rem;
            min-height: 18rem;
        }
        /* Portrait reveal start: a centred ~2:3 box (squarer than the previous
           tall strip), cropped on all four sides with soft rounded corners.
           Updating just the variable, not the animation-name, prevents the
           reveal from replaying when the user drags across the breakpoint. */
        .a2-hero__video {
            --cinema-from: inset(28% 18% 28% 18% round 18px);
        }
        /* Force the headline/CTA stack to stay vertical at mobile/half-laptop
           even when the panel's own container query would otherwise make it a
           row at >= 34rem panel width. CTA stretches full width of the panel. */
        .a2-panel__main {
            flex-direction: column;
            align-items: stretch;
        }
        .a2-discover {
            width: 100%;
            align-self: stretch;
            justify-content: space-between;
            padding: 1rem 1.05rem;
        }
        .a2-panel :global(.a2-services) {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.55rem 1rem;
        }
        .a2-panel :global(.a2-services .services__sep) {
            display: none;
        }
    }

    /* Video now plays at every viewport (the small-screen hide rule was
       removed). Reduced-motion still skips the cinema reveal and the
       navbar fade-in. */
    /* At the very smallest widths, drop the wordmark text to just the Z² mark so
       the nav actions (language, account, book) keep breathing room. */
    @media (max-width: 22.5rem) {
        .a2-brand__type {
            display: none;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .a2-nav {
            animation: none !important;
        }
        .a2-hero__video {
            display: none;
            animation: none;
            clip-path: inset(0);
        }
    }
</style>

<script>
    // After the initial reveal sequence completes (~2.5s buffer), flag the
    // .a2 wrapper as revealed. Once flagged, the navbar's reveal animation is
    // dropped in favour of a simple opacity:1 — so any subsequent resize
    // across the 47rem breakpoint just tweens the opacity over 250ms,
    // instead of replaying the 1500ms-delayed reveal. This is what stops
    // the strip from flickering during drag-resize.
    const markRevealed = () =>
        document.querySelector(".a2")?.classList.add("is-revealed");
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        markRevealed();
    } else {
        setTimeout(markRevealed, 2500);
    }

    // Language dropdown: toggle on button click, close on outside click /
    // Escape. The Korean option is a placeholder (no real translation wired
    // yet) — selecting it just closes the menu. When the Korean copy lands,
    // swap the option's onclick for a route change (Astro i18n: /ko/).
    document.addEventListener("DOMContentLoaded", () => {
        const wrap = document.querySelector(".a2-lang-wrap");
        if (!wrap) return;
        const button = wrap.querySelector(".a2-lang");
        const menu = wrap.querySelector(".a2-lang__menu");
        if (!button || !menu) return;
        // Paused: while the menu carries the `hidden` attribute we don't wire
        // any toggle behaviour, so clicking the En button is a no-op until
        // the dropdown is re-enabled.
        if (menu.hasAttribute("hidden")) return;

        const open = () => {
            wrap.dataset.open = "true";
            button.setAttribute("aria-expanded", "true");
        };
        const close = () => {
            delete wrap.dataset.open;
            button.setAttribute("aria-expanded", "false");
        };

        button.addEventListener("click", (e) => {
            e.stopPropagation();
            wrap.dataset.open === "true" ? close() : open();
        });

        menu.querySelectorAll(".a2-lang__option").forEach((opt) => {
            opt.addEventListener("click", (e) => {
                e.stopPropagation();
                // TODO: when Korean copy lands, switch route here
                // const lang = opt.dataset.lang;
                // if (lang === "ko") window.location.href = "/ko/";
                close();
            });
        });

        document.addEventListener("click", (e) => {
            if (!wrap.contains(e.target as Node)) close();
        });
        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape") close();
        });
    });
</script>
