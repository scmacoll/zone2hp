---
// Step 2: choose a booking type (data-driven from funnel.ts). Tile hrefs carry
// the upstream `customer` param, which only exists client-side on a static site,
// so they are hydrated by the script below.
import BookingShell from '../../components/booking/BookingShell.astro';
import { BOOKING_TYPES } from '../../lib/booking/funnel';
---

<BookingShell step="type">
  <p class="step__lede">What kind of appointment do you need?</p>
  <div class="choices">
    {
      BOOKING_TYPES.map((t) => (
        <a class="choice" data-next-type={t.id} href={`/book/scope?type=${t.id}`}>
          <span class="choice__title">{t.label}</span>
          <span class="choice__blurb">{t.blurb}</span>
        </a>
      ))
    }
  </div>
</BookingShell>

<script>
  import { parseBookingParams, buildStepUrl } from '../../lib/booking/funnel-state';
  import type { BookingType } from '../../lib/booking/funnel';

  const params = parseBookingParams(new URLSearchParams(window.location.search));
  document.querySelectorAll<HTMLAnchorElement>('[data-next-type]').forEach((a) => {
    a.href = buildStepUrl('scope', { ...params, type: a.dataset.nextType as BookingType });
  });
</script>
