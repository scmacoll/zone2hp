---
import Base from '../../layouts/Base.astro';
import PageHeader from '../../components/PageHeader.astro';
import Footer from '../../components/Footer.astro';
import Eyebrow from '../../components/Eyebrow.astro';
import AccountForm from '../../components/account/AccountForm.astro';
---

<Base
  title="Create an account | Zone Two Health and Performance"
  description="Create a Zone Two Health and Performance account for updates and early access."
  noindex
>
  <PageHeader />
  <main id="main" class="account">
    <header class="account__intro">
      <Eyebrow tone="accent">Account</Eyebrow>
      <h1 class="account__title">Create an account</h1>
      <p class="account__lede">
        For clinic updates, early access and member notes. This is a general account, not a patient or
        medical record. We do not collect any health information here.
      </p>
      <p class="account__preview">Preview: accounts are not connected to a live system yet.</p>
    </header>

    <AccountForm mode="signup" />

    <p class="account__alt">Already have an account? <a href="/account/login">Sign in</a>.</p>
  </main>
  <Footer />
</Base>

<style>
  .account__intro {
    max-width: 28rem;
    margin-inline: auto;
    padding-inline: var(--section-pad-inline);
    padding-top: var(--space-lg);
    padding-bottom: var(--space-md);
    display: grid;
    gap: var(--space-2xs);
  }
  .account__title {
    font-size: clamp(2rem, 1.4rem + 2vw, 3rem);
  }
  .account__lede {
    color: var(--ink-2);
  }
  .account__preview {
    margin-top: var(--space-2xs);
    font-family: var(--font-mono);
    font-size: var(--step-small);
    color: var(--ink-3);
  }
  .account__alt {
    max-width: 28rem;
    margin-inline: auto;
    margin-top: var(--space-md);
    padding-inline: var(--section-pad-inline);
    padding-bottom: var(--space-2xl);
    font-size: var(--step-small);
    color: var(--ink-2);
  }
  .account__alt a {
    color: var(--accent-deep);
  }
</style>
